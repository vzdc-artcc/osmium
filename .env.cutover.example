# Production cutover env template.
# Copy to .env.cutover and replace every placeholder before first use.

# Compose / image selection
OSMIUM_IMAGE=ghcr.io/vzdc-artcc/osmium:latest-abcdef0
OSMIUM_API_HOST_PORT=3000
OSMIUM_FILES_DIR=/srv/osmium/files
OSMIUM_DUMP_DIR=/srv/osmium/dumps

# Target Osmium Postgres
OSMIUM_POSTGRES_DB=osmium
OSMIUM_POSTGRES_USER=osmium
OSMIUM_POSTGRES_PASSWORD=change-me

# Osmium API runtime
BIND_ADDR=0.0.0.0:3000
DATABASE_URL=postgres://osmium:change-me@postgres:5432/osmium
RUST_LOG=info
RUN_MIGRATIONS_ON_STARTUP=true
COOKIE_SECURE=true
CORS_ALLOWED_ORIGINS=https://app.example.org
OSMIUM_SERVER_ADMIN_CID=

# Use production OAuth hosts in production.
VATSIM_DEV_MODE=false
VATSIM_CLIENT_ID=replace-me
VATSIM_CLIENT_SECRET=replace-me
VATSIM_REDIRECT_URI=https://api.example.org/api/v1/auth/vatsim/callback
VATSIM_AUTHORIZE_URL=https://auth.vatsim.net/oauth/authorize
VATSIM_TOKEN_URL=https://auth.vatsim.net/oauth/token
VATSIM_USERINFO_URL=https://auth.vatsim.net/api/user
VATSIM_SCOPE="full_name email vatsim_details country"
VATSIM_CLIENT_AUTH_METHOD=basic

# Workers stay off during cutover verification.
STATS_SYNC_ENABLED=false
STATS_SYNC_INTERVAL_SECS=5
STATS_SYNC_STALE_SECS=300
ROSTER_SYNC_ENABLED=false
ROSTER_SYNC_INTERVAL_SECS=900
EMAIL_ENABLED=false
EMAIL_WORKER_ENABLED=false
EMAIL_WORKER_INTERVAL_SECS=5
EMAIL_WORKER_BATCH_SIZE=25

# VATUSA / facility
VATUSA_API_KEY=replace-me
VATUSA_FACILITY_ID=ZDC
VATUSA_API_BASE_URL=https://api.vatusa.net/v2

# File CDN / asset service
FILE_STORAGE_ROOT=/app/storage/files
FILE_MAX_UPLOAD_BYTES=26214400
FILE_SIGNING_SECRET=replace-me
# Generate with: openssl rand -hex 32
FILE_ENCRYPTION_KEY_HEX=
CDN_BASE_URL=https://api.example.org

# Email / AWS SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
AWS_SESSION_TOKEN=
EMAIL_SES_ENDPOINT=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Osmium
EMAIL_REPLY_TO_ADDRESS=
EMAIL_UNSUBSCRIBE_BASE_URL=https://www.example.org
EMAIL_UNSUBSCRIBE_SECRET=replace-me
