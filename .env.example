BIND_ADDR=0.0.0.0:3000
DATABASE_URL=postgres://postgres:postgres@localhost:5432/osmium
RUST_LOG=info,tower_http=debug
RUN_MIGRATIONS_ON_STARTUP=true
COOKIE_SECURE=false
API_DEV_MODE=false
VATSIM_DEV_MODE=true
VATSIM_CLIENT_ID=your-client-id
VATSIM_CLIENT_SECRET=your-client-secret
# Use one canonical local origin everywhere. Do not mix localhost and 127.0.0.1.
VATSIM_REDIRECT_URI=http://127.0.0.1:3000/api/v1/auth/vatsim/callback
VATSIM_AUTHORIZE_URL=https://auth-dev.vatsim.net/oauth/authorize
VATSIM_TOKEN_URL=https://auth-dev.vatsim.net/oauth/token
VATSIM_USERINFO_URL=https://auth-dev.vatsim.net/api/user
VATSIM_SCOPE=full_name email vatsim_details country
# VATSIM dev mode should use post client authentication.
VATSIM_CLIENT_AUTH_METHOD=post
VATUSA_API_KEY=
VATUSA_FACILITY_ID=ZDC
VATUSA_API_BASE_URL=https://api.vatusa.net/v2
ROSTER_SYNC_ENABLED=true
ROSTER_SYNC_INTERVAL_SECS=900

# File CDN / asset service
# For Docker: /app/storage/files (uses osmium-files-data volume)
# For local development: ./storage/files
FILE_STORAGE_ROOT=/app/storage/files
FILE_MAX_UPLOAD_BYTES=26214400
FILE_SIGNING_SECRET=change-me-in-production
# Optional: 64-char hex key for AES-256-GCM at-rest file encryption.
# Example generation: openssl rand -hex 32
FILE_ENCRYPTION_KEY_HEX=
CDN_BASE_URL=http://127.0.0.1:3000
